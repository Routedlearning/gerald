# Fast-path fitness Telegram bot environment variables.
# Copy to .env and fill real values.
# IMPORTANT: never commit real .env files; add `.env` to .gitignore before any real use.

# Telegram bot token from @BotFather for the fitness fast-path bot only.
TELEGRAM_BOT_TOKEN=
# Only this chat_id may use the fast path.
GERALD_ALLOWED_CHAT_ID=7435551643
# Local inbound handler endpoint.
GERALD_INBOUND_URL=http://127.0.0.1:8080/telegram/feedback
# Optional: set 1 to include parse/write/total timing in responses.
GERALD_DEBUG_TIMING=
# Optional dry-run mode: no HTTP requests to local handler.
GERALD_DRY_RUN=
